{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": "test/.*\\.real-e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 180000,
  "forceExit": true,
  "globalSetup": "<rootDir>/test/global-setup.ts",
  "globalTeardown": "<rootDir>/test/global-teardown.ts",
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@inite/knowledge$": "<rootDir>/../inite-shared/packages/knowledge/src/index.ts"
  }
}
